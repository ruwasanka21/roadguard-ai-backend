# RoadGuard AI Backend — Environment Variables
# Copy this file to .env and fill in your real keys.

# Google Maps / Elevation API key (server-side key, no referrer restrictions)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Server host & port (used by uvicorn)
HOST=0.0.0.0
PORT=8000

# Set to "production" to disable /docs and enable stricter CORS
ENV=development
